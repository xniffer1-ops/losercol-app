# Base de datos Neon/Postgres
DATABASE_URL="postgresql://usuario:password@host/database?sslmode=require"

# Obligatorio en Vercel. Debe tener mínimo 32 caracteres.
# Puedes generar uno con: npm run generar:secret
JWT_SECRET="pega_aqui_un_secreto_largo_de_minimo_32_caracteres"

# Solo para recuperar acceso temporalmente con /api/setup-admin?token=...
# Después de usarlo, puedes borrar estas variables de Vercel.
ADMIN_SETUP_TOKEN="pega_un_token_largo_temporal"
ADMIN_SETUP_EMAIL="soporte@losercol.com"
ADMIN_SETUP_NOMBRE="Soporte LOSERCOL"
ADMIN_SETUP_PASSWORD="cambia_esta_clave_temporal"

# WhatsApp / Evolution API cuando ya tengas servidor real
EVOLUTION_API_URL="https://tu-servidor-evolution.com"
EVOLUTION_API_KEY="tu_api_key"
EVOLUTION_INSTANCE="nombre_de_tu_instancia"
